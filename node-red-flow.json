[
    {
        "id": "tab_main",
        "type": "tab",
        "label": "Smart Bus Conductor Tests",
        "disabled": false,
        "info": "Testing flows for bus-break and disembark scenarios"
    },
    {
        "id": "inject_create_trip",
        "type": "inject",
        "z": "tab_main",
        "name": "1. Create Test Trip",
        "props": [{"p": "payload"}],
        "repeat": "",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 140,
        "y": 80,
        "wires": [["func_generate_trip"]]
    },
    {
        "id": "func_generate_trip",
        "type": "function",
        "z": "tab_main",
        "name": "Generate Ticket Data",
        "func": "const timestamp = Date.now();\nconst random = Math.random().toString(36).substring(2, 8).toUpperCase();\nconst ticketId = `BUS-${timestamp}-${random}`;\n\nmsg.payload = {\n    phone_number: \"+263771234567\",\n    origin_lat: -20.1500,\n    origin_lng: 28.5667,\n    destination_name: \"Harare\",\n    destination_lat: -17.8292,\n    destination_lng: 31.0522,\n    distance_km: 439.2,\n    fare: 15.0,\n    qr_code: ticketId\n};\n\nflow.set('currentTicketId', ticketId);\nflow.set('tripCreated', true);\nnode.status({fill:\"blue\", shape:\"dot\", text:`Ticket: ${ticketId}`});\n\nreturn msg;",
        "outputs": 1,
        "x": 360,
        "y": 80,
        "wires": [["http_create_trip"]]
    },
    {
        "id": "http_create_trip",
        "type": "http request",
        "z": "tab_main",
        "name": "POST /api/trips/create/",
        "method": "POST",
        "ret": "obj",
        "url": "http://localhost:8000/api/trips/create/",
        "tls": "",
        "persist": false,
        "proxy": "",
        "authType": "",
        "x": 600,
        "y": 80,
        "wires": [["debug_create"]]
    },
    {
        "id": "debug_create",
        "type": "debug",
        "z": "tab_main",
        "name": "Trip Created",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": true,
        "complete": "payload",
        "targetType": "msg",
        "x": 820,
        "y": 80,
        "wires": []
    },
    {
        "id": "inject_disembark",
        "type": "inject",
        "z": "tab_main",
        "name": "2. Test Disembark",
        "props": [{"p": "payload"}],
        "repeat": "",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 140,
        "y": 180,
        "wires": [["func_prep_disembark"]]
    },
    {
        "id": "func_prep_disembark",
        "type": "function",
        "z": "tab_main",
        "name": "Prepare QR Validation",
        "func": "const ticketId = flow.get('currentTicketId');\n\nif (!ticketId) {\n    node.error(\"No ticket ID found. Create a trip first!\");\n    node.status({fill:\"red\", shape:\"ring\", text:\"No ticket - create trip first\"});\n    return null;\n}\n\nmsg.payload = {\n    qr_code: ticketId\n};\n\nnode.status({fill:\"yellow\", shape:\"ring\", text:`Disembarking: ${ticketId}`});\n\nreturn msg;",
        "outputs": 1,
        "x": 370,
        "y": 180,
        "wires": [["http_validate_disembark"]]
    },
    {
        "id": "http_validate_disembark",
        "type": "http request",
        "z": "tab_main",
        "name": "POST /api/trips/validate/",
        "method": "POST",
        "ret": "obj",
        "url": "http://localhost:8000/api/trips/validate/",
        "tls": "",
        "persist": false,
        "proxy": "",
        "authType": "",
        "x": 630,
        "y": 180,
        "wires": [["debug_disembark"]]
    },
    {
        "id": "debug_disembark",
        "type": "debug",
        "z": "tab_main",
        "name": "Disembark Result",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": true,
        "complete": "payload",
        "targetType": "msg",
        "x": 870,
        "y": 180,
        "wires": []
    },
    {
        "id": "inject_break_out",
        "type": "inject",
        "z": "tab_main",
        "name": "3a. Bus Break - Going Out",
        "props": [{"p": "payload"}],
        "repeat": "",
        "crontab": "",

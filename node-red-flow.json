    {
        "id": "func_going_out",
        "type": "function",
        "z": "tab_main",
        "name": "Mark Passenger Outside",
        "func": "const ticketId = flow.get('currentTicketId');\n\nif (!ticketId) {\n    node.error(\"No ticket ID found. Create a trip first!\");\n    node.status({fill:\"red\", shape:\"ring\", text:\"No ticket\"});\n    return null;\n}\n\nmsg.payload = {\n    qr_code: ticketId\n};\n\nflow.set('passengerOutside', true);\nnode.status({fill:\"orange\", shape:\"dot\", text:`OUTSIDE: ${ticketId}`});\n\nreturn msg;",
        "outputs": 1,
        "x": 400,
        "y": 280,
        "wires": [["http_validate_out"]]
    },
    {
        "id": "http_validate_out",
        "type": "http request",
        "z": "tab_main",
        "name": "Validate Going Out",

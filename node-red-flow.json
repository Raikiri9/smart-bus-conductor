        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": true,
        "complete": "payload",
        "targetType": "msg",
        "x": 860,
        "y": 280,
        "wires": []
    },
    {
        "id": "inject_break_in",
        "type": "inject",
        "z": "tab_main",
        "name": "3b. Bus Break - Coming In",
        "props": [{"p": "payload"}],
        "repeat": "",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 170,
        "y": 360,
        "wires": [["func_coming_in"]]
    },
    {
        "id": "func_coming_in",
        "type": "function",
        "z": "tab_main",
        "name": "Mark Passenger Inside",
        "func": "const ticketId = flow.get('currentTicketId');\nconst isOutside = flow.get('passengerOutside');\n\nif (!ticketId) {\n    node.error(\"No ticket ID found. Create a trip first!\");\n    node.status({fill:\"red\", shape:\"ring\", text:\"No ticket\"});\n    return null;\n}\n\nif (!isOutside) {\n    node.warn(\"Passenger not marked as outside!\");\n}\n\nmsg.payload = {\n    qr_code: ticketId\n};\n\nflow.set('passengerOutside', false);\nnode.status({fill:\"green\", shape:\"dot\", text:`INSIDE: ${ticketId}`});\n\nreturn msg;",
        "outputs": 1,
        "x": 400,
        "y": 360,
        "wires": [["http_validate_in"]]
    },
    {
        "id": "http_validate_in",
        "type": "http request",
        "z": "tab_main",
        "name": "Validate Coming In",
        "method": "POST",
        "ret": "obj",
        "url": "http://localhost:8000/api/trips/validate/",
        "tls": "",
        "persist": false,
        "proxy": "",
        "authType": "",
        "x": 640,
        "y": 360,
        "wires": [["debug_in"]]
    },
    {
        "id": "debug_in",
        "type": "debug",
        "z": "tab_main",
        "name": "Coming In Status",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": true,
        "complete": "payload",
        "targetType": "msg",
        "x": 860,
        "y": 360,
        "wires": []
    },
    {
        "id": "inject_active_trips",
        "type": "inject",
        "z": "tab_main",
        "name": "4. Get Active Trips",
        "props": [{"p": "payload"}],
        "repeat": "10",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 160,
        "y": 460,
        "wires": [["http_active_trips"]]
    },
    {
        "id": "http_active_trips",
        "type": "http request",
        "z": "tab_main",
        "name": "GET /api/trips/active/",
        "method": "GET",
        "ret": "obj",
        "url": "http://localhost:8000/api/trips/active/",
        "tls": "",
        "persist": false,
        "proxy": "",
        "authType": "",
        "x": 390,
        "y": 460,
        "wires": [["func_process_active"]]
    },
    {
        "id": "func_process_active",
        "type": "function",
        "z": "tab_main",
        "name": "Process Active Trips",
        "func": "const activeTrips = msg.payload;\n\nif (!Array.isArray(activeTrips)) {\n    node.status({fill:\"red\", shape:\"ring\", text:\"Invalid response\"});\n    return null;\n}\n\nnode.status({\n    fill: activeTrips.length > 0 ? \"green\" : \"grey\",\n    shape: \"dot\",\n    text: `Active: ${activeTrips.length} passengers`\n});\n\nmsg.payload = {\n    count: activeTrips.length,\n    trips: activeTrips.map(t => ({\n        id: t.id,\n        destination: t.destination_name,\n        distance: `${t.distance_km} km`\n    }))\n};\n\nreturn msg;",
        "outputs": 1,
        "x": 630,
        "y": 460,
        "wires": [["debug_active"]]
    },
    {
        "id": "debug_active",
        "type": "debug",
        "z": "tab_main",
        "name": "Active Trips Monitor",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": false,
        "complete": "payload",
        "targetType": "msg",
        "x": 870,
        "y": 460,
        "wires": []
    },

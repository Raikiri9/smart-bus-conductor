        "ret": "obj",
        "url": "http://localhost:8000/api/trips/validate/",
        "tls": "",
        "persist": false,
        "proxy": "",
        "authType": "",
        "x": 640,
        "y": 280,
        "wires": [["debug_out"]]
    },
    {
        "id": "debug_out",
